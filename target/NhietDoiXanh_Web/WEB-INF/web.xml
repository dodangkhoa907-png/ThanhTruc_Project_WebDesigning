<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee
                             https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd"
         version="6.0">

    <display-name>Nhiệt Đới Xanh - Landing Page</display-name>

    <!-- ===== Asset cache-bust version — MỘT chỗ duy nhất =====
         CSS/JS dùng chung (/css/*, /js/*) có Cache-Control: immutable, max-age=7 ngày
         (xem CacheHeaderFilter). Query string ?v=N là cách duy nhất buộc trình duyệt tải
         lại khi nội dung đổi. TRƯỚC ĐÂY mỗi JSP tự ghi số version riêng — 3 lần liên tiếp
         (Prompt 6, 7) một trang bị sửa CSS dùng chung nhưng quên bump version, khiến trình
         duyệt đã cache trang khác tiếp tục phục vụ CSS cũ trong 7 ngày. Từ nay: TẤT CẢ
         JSP tham chiếu CSS/JS dùng chung qua ${initParam.assetVer} — sửa bất kỳ file CSS/JS
         dùng chung nào (style.css, product.css, account.css, menu.css, cart.js, checkout.js)
         → chỉ cần tăng số này lên 1. -->
    <context-param>
        <param-name>assetVer</param-name>
        <param-value>23</param-value>
    </context-param>

    <!-- ===== Session timeout — khai báo tường minh thay vì phụ thuộc mặc định ngầm của
         Tomcat (30 phút). AdminAuth.MAX_AGE_SECONDS (cookie admin riêng) đã hard-code khớp
         giá trị này — đổi 1 trong 2 nhớ đổi luôn cái kia. ===== -->
    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>

    <!-- ===== Welcome File ===== -->
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <!-- ===== Character Encoding Filter (UTF-8) ===== -->
    <filter>
        <filter-name>CharacterEncodingFilter</filter-name>
        <filter-class>com.nhietdoixanh.util.EncodingFilter</filter-class>
        <init-param>
            <param-name>encoding</param-name>
            <param-value>UTF-8</param-value>
        </init-param>
    </filter>
    <filter-mapping>
        <filter-name>CharacterEncodingFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <!-- ===== Default JSP source encoding (Jasper reads statically-included
         fragments as their own translation unit for encoding purposes; files
         without their own page directive would otherwise fall back to a
         non-UTF-8 platform default, corrupting Vietnamese text). ===== -->
    <jsp-config>
        <jsp-property-group>
            <url-pattern>*.jsp</url-pattern>
            <url-pattern>*.jspf</url-pattern>
            <page-encoding>UTF-8</page-encoding>
        </jsp-property-group>
    </jsp-config>

    <!-- ===== Error Pages ===== -->
    <error-page>
        <error-code>404</error-code>
        <location>/WEB-INF/views/error.jsp</location>
    </error-page>
    <error-page>
        <error-code>500</error-code>
        <location>/WEB-INF/views/error.jsp</location>
    </error-page>

</web-app>
